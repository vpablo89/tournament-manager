      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', function () { pm.response.to.have.status(200); });"] } }]
    },
    {
      "name": "GET /players/ranking",
      "request": { "method": "GET", "url": "{{baseUrl}}/players/ranking" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', function () { pm.response.to.have.status(200); });"] } }]
    },
    {
      "name": "GET /registrations",
      "request": { "method": "GET", "url": "{{baseUrl}}/registrations" },
